# Copy this file to .env and fill in your own values.
# Never commit your actual .env file.

# Gmail address to poll
EMAIL_ADDRESS=you@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# See README.md > "Getting a Gmail App Password" for how to generate one.
APP_PASSWORD=xxxx xxxx xxxx xxxx

# Folder where notes + attachments are written (created if it doesn't exist)
OUTPUT_FOLDER=./pogo_inbox

# How often to poll, in seconds
POLL_INTERVAL=60

# Only emails whose subject contains this string are collected;
# it's stripped from the subject title
TRIGGER=!pogo